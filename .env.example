APP_ENV=prod
APP_TIMEZONE=Asia/Tashkent
APP_WEBHOOK_TOKEN=change_me_strong

DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=callqueue;charset=utf8mb4
DB_USER=root
DB_PASS=pass

# Bitrix incoming webhook base:
# Example: https://yourdomain.bitrix24.ru/rest/1/xxxxxxxxxxxxxxxx/
BITRIX_WEBHOOK_BASE=https://YOUR.bitrix24.ru/rest/1/YOUR_WEBHOOK_TOKEN/

BITRIX_SCORE_FIELD=UF_CRM_1766473558

# Telephony
TEL_BASE=https://imanhalal.sip.uz
TEL_API_KEY=YOUR_KEY

# how many days back we check history (fallback mode)
TEL_HISTORY_LOOKBACK_DAYS=180

# PBX user mapping (Bitrix user -> PBX ext/login)
# храните в json, чтобы не городить админку
PBX_MAP_JSON={"1":"100","2":"101","5":"200"}
